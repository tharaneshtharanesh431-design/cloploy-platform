flowchart LR
  user[User Browser] --> web[React Frontend]
  web --> api[Express API]
  api --> mongo[(MongoDB)]
  api --> github[GitHub OAuth + Repos]
  api --> ai[OpenAI/Gemini Compatible AI]
  api --> jenkins[Jenkins Pipeline]
  jenkins --> sonar[SonarQube]
  jenkins --> docker[Docker Build]
  docker --> ecr[AWS ECR]
  jenkins --> tf[Terraform]
  tf --> aws[AWS VPC + EKS + S3 + IAM]
  ecr --> eks[EKS]
  api --> socket[Socket.io]
  eks --> prom[Prometheus]
  eks --> logs[ELK Stack]
  prom --> grafana[Grafana]
