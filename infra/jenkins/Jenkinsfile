pipeline {
  agent any
  environment {
    AWS_REGION = credentials('aws-region')
    SONAR_TOKEN = credentials('sonarqube-token')
    ECR_REGISTRY = credentials('ecr-registry')
  }
  parameters {
    string(name: 'PROJECT_SLUG', defaultValue: 'cloploy-app', description: 'Project slug')
    string(name: 'DEPLOYMENT_ID', defaultValue: '', description: 'Deployment ID')
    string(name: 'REPOSITORY_URL', defaultValue: '', description: 'Repository URL')
    string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch')
  }
  stages {
    stage('Checkout') {
      steps {
        git branch: params.BRANCH, url: params.REPOSITORY_URL
      }
    }
    stage('Install') {
      steps {
        sh 'test -f package.json && npm ci || true'
      }
    }
    stage('Build') {
      steps {
        sh 'test -f package.json && npm run build || true'
      }
    }
    stage('Test') {
      steps {
        sh 'test -f package.json && npm test -- --runInBand || true'
      }
    }
    stage('SonarQube') {
      steps {
        sh 'sonar-scanner -Dsonar.projectKey=${PROJECT_SLUG} -Dsonar.sources=. -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.token=${SONAR_TOKEN}'
      }
    }
    stage('Docker Build') {
      steps {
        sh 'docker build -t ${ECR_REGISTRY}/${PROJECT_SLUG}:${BUILD_NUMBER} .'
      }
    }
    stage('Push ECR') {
      steps {
        sh 'aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}'
        sh 'docker push ${ECR_REGISTRY}/${PROJECT_SLUG}:${BUILD_NUMBER}'
      }
    }
    stage('Terraform') {
      steps {
        dir('infra/terraform') {
          sh 'terraform init'
          sh 'terraform apply -auto-approve -var project_slug=${PROJECT_SLUG} -var image_tag=${BUILD_NUMBER}'
        }
      }
    }
    stage('Kubernetes Deploy') {
      steps {
        sh 'kubectl apply -f infra/kubernetes/'
        sh 'kubectl rollout status deployment/${PROJECT_SLUG} -n ${PROJECT_SLUG}'
      }
    }
    stage('Health Check') {
      steps {
        sh 'curl -fsS https://${PROJECT_SLUG}.cloploy.app/health || exit 1'
      }
    }
  }
}
